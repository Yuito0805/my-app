<!DOCTYPE html>
<html lang="ja">
<%- include("partials/head", { title: "教科書を探す" }) %>
<body>
  <%- include("partials/nav", { currentAccount, currentPath, unreadCount }) %>
  <%- include("partials/messages", { notice, error }) %>

  <main class="home-main">
    <section class="hero hero-v11">
      <div class="hero-orb hero-orb-one" aria-hidden="true"></div>
      <div class="hero-orb hero-orb-two" aria-hidden="true"></div>
      <div class="hero-content hero-content-wide">
        <div class="hero-copy">
          <span class="hero-eyebrow">KEIO TEXTBOOK CIRCULATION</span>
          <h1>次の授業に必要な一冊を、<br><span>学生同士で見つけよう。</span></h1>
          <p>履修科目と利用履歴から、必要になりそうな教科書を優先して表示します。金銭の仲介は行いません。</p>
          <div class="hero-trust-row"><span>✓ 教科名から検索</span><span>✓ おすすめを個別化</span><span>✓ チャットで相談</span></div>
        </div>

        <div class="hero-search-card">
          <form class="search-panel search-panel-v11" action="/" method="get" data-search-form>
            <div class="search-row">
              <div class="search-input-wrap search-input-v11">
                <span class="search-icon" aria-hidden="true">⌕</span>
                <input id="q" type="search" name="q" value="<%= q %>" placeholder="教科書名・教科名・担当教員名" autocomplete="off" data-search-input aria-autocomplete="list" aria-controls="search-suggestions">
                <div id="search-suggestions" class="search-suggestions" data-search-suggestions role="listbox" aria-label="検索候補"></div>
              </div>
              <button class="primary search-button" type="submit">検索</button>
            </div>

            <button class="filter-drawer-toggle" type="button" data-filter-toggle aria-expanded="false" aria-controls="advanced-filter-panel">☷ 絞り込み・並び替え</button>
            <div id="advanced-filter-panel" class="advanced-search-grid filter-panel" data-filter-panel>
              <label class="compact-field"><span>検索対象</span><select name="target" data-search-target>
                <option value="all" <%= searchTarget === 'all' ? 'selected' : '' %>>すべて</option>
                <option value="title" <%= searchTarget === 'title' ? 'selected' : '' %>>教科書名</option>
                <option value="author" <%= searchTarget === 'author' ? 'selected' : '' %>>著者名</option>
                <option value="course" <%= searchTarget === 'course' ? 'selected' : '' %>>教科名</option>
                <option value="teacher" <%= searchTarget === 'teacher' ? 'selected' : '' %>>担当教員名</option>
              </select></label>
              <label class="compact-field"><span>本の状態</span><select name="condition"><option value="all">すべて</option><% conditionOptions.forEach(option => { %><option value="<%= option %>" <%= conditionFilter === option ? 'selected' : '' %>><%= option %></option><% }) %></select></label>
              <label class="compact-field"><span>取引状態</span><select name="status">
                <option value="open" <%= statusFilter === 'open' ? 'selected' : '' %>>募集中</option>
                <option value="negotiating" <%= statusFilter === 'negotiating' ? 'selected' : '' %>>交渉中</option>
                <option value="completed" <%= statusFilter === 'completed' ? 'selected' : '' %>>譲渡完了</option>
                <option value="all" <%= statusFilter === 'all' ? 'selected' : '' %>>すべて</option>
              </select></label>
              <label class="compact-field"><span>並び順</span><select name="sort">
                <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>新着順</option>
                <option value="updated" <%= sort === 'updated' ? 'selected' : '' %>>更新順</option>
                <option value="condition" <%= sort === 'condition' ? 'selected' : '' %>>状態順</option>
                <option value="popular" <%= sort === 'popular' ? 'selected' : '' %>>注目順</option>
              </select></label>
            </div>
          </form>

          <% const hasActiveFilters = q || searchTarget !== 'all' || conditionFilter !== 'all' || statusFilter !== 'open' || sort !== 'newest'; %>
          <% if (hasActiveFilters) { %>
            <div class="active-filter-area"><span class="active-filter-label">適用中</span><div class="filter-chip-list">
              <% if (q) { %><a class="filter-chip" href="<%= filterChipUrls.keyword %>">キーワード：<%= q %> ×</a><% } %>
              <% if (searchTarget !== 'all') { %><a class="filter-chip" href="<%= filterChipUrls.target %>">検索対象 ×</a><% } %>
              <% if (conditionFilter !== 'all') { %><a class="filter-chip" href="<%= filterChipUrls.condition %>"><%= conditionFilter %> ×</a><% } %>
              <% if (statusFilter !== 'open') { %><a class="filter-chip" href="<%= filterChipUrls.status %>">取引状態 ×</a><% } %>
              <% if (sort !== 'newest') { %><a class="filter-chip" href="<%= filterChipUrls.sort %>">並び順 ×</a><% } %>
            </div><a class="clear-filter-link" href="/">すべて解除</a></div>
          <% } %>

          <% if (currentAccount) { %>
            <form class="save-search-panel save-search-v11" action="/saved-searches" method="post">
              <input type="hidden" name="keyword" value="<%= q %>"><input type="hidden" name="searchTarget" value="<%= searchTarget %>"><input type="hidden" name="condition" value="<%= conditionFilter %>"><input type="hidden" name="itemStatus" value="<%= statusFilter %>"><input type="hidden" name="sortOrder" value="<%= sort %>"><input type="hidden" name="returnTo" value="<%= currentUrl %>">
              <label><span>この条件を保存</span><input type="text" name="name" maxlength="40" placeholder="例：アルゴリズム理論・募集中" required></label><button class="secondary" type="submit">保存</button>
            </form>
          <% } %>
        </div>
      </div>
    </section>

    <% if (activeSavedSearch) { %><section class="saved-search-banner"><div><span class="section-eyebrow">SAVED SEARCH</span><strong>「<%= activeSavedSearch.name %>」の結果</strong><p>今回の表示時刻を新着確認日時として保存しました。</p></div><a class="button-link secondary small-button" href="/mypage?tab=saved">保存した検索を管理</a></section><% } %>

    <% if (currentAccount && isDefaultBrowse && homeShelves) { %>
      <section class="personalized-dashboard">
        <% if (homeShelves.enrolledCourses.length > 0 && homeShelves.courseItems.length > 0) { %>
          <%- include("partials/item-shelf", { shelfId:'enrolled', eyebrow:'YOUR COURSES', title:'履修科目の新着', description:homeShelves.enrolledCourses.slice(0,4).map(c=>c.courseName).join('・')+' に関連する募集中の教科書', items:homeShelves.courseItems, actionHref:'/mypage?tab=courses', actionLabel:'履修科目を設定', currentAccount, favoriteItemIds, currentUrl, showRecommendationFeedback:false, reasonResolver:()=> '履修中の教科', reasonsResolver:()=>[], scoreResolver:()=>0, getItemStatusClass, getItemStatusLabel }) %>
        <% } else { %>
          <section class="course-onboarding-card"><div class="course-onboarding-icon">✦</div><div><span class="section-eyebrow">PERSONALIZE</span><h2>履修科目を登録すると、必要な本を先に表示できます</h2><p>マイページで最大12科目まで選択できます。</p></div><a class="button-link primary" href="/mypage?tab=courses">履修科目を設定</a></section>
        <% } %>

        <% if (recommendationSection && recommendationSection.items.length > 0) { %>
          <%- include("partials/item-shelf", { shelfId:'recommended', eyebrow:'FOR YOU', title:recommendationSection.title, description:recommendationSection.description, items:recommendationSection.items, actionHref:'/mypage?tab=favorites', actionLabel:'好みを確認', currentAccount, favoriteItemIds, currentUrl, showRecommendationFeedback:true, reasonResolver:item=>item.recommendationReason, reasonsResolver:item=>item.recommendationReasons, scoreResolver:item=>item.recommendationScore, getItemStatusClass, getItemStatusLabel }) %>
        <% } %>
        <% if (homeShelves.trendingItems.length > 0) { %>
          <%- include("partials/item-shelf", { shelfId:'trending', eyebrow:'TRENDING', title:'いま注目されている教科書', description:'閲覧数とお気に入り数が増えている募集中の出品です。', items:homeShelves.trendingItems, actionHref:'/?sort=popular', actionLabel:'注目順で見る', currentAccount, favoriteItemIds, currentUrl, showRecommendationFeedback:false, reasonResolver:()=> '人気上昇中', reasonsResolver:()=>[], scoreResolver:()=>0, getItemStatusClass, getItemStatusLabel }) %>
        <% } %>
        <% if (homeShelves.recentItems.length > 0) { %>
          <%- include("partials/item-shelf", { shelfId:'recent-home', eyebrow:'RECENTLY VIEWED', title:'最近見た教科書', description:'前に見た出品へすぐ戻れます。', items:homeShelves.recentItems, actionHref:'/mypage?tab=recent', actionLabel:'履歴を見る', currentAccount, favoriteItemIds, currentUrl, showRecommendationFeedback:false, reasonResolver:item=>'最終閲覧 '+formatRelativeDate(item.lastViewedAt), reasonsResolver:()=>[], scoreResolver:()=>0, getItemStatusClass, getItemStatusLabel }) %>
        <% } %>
      </section>
    <% } %>

    <section class="catalog-section">
      <div class="result-bar result-bar-v11"><div><span class="section-eyebrow">CATALOG</span><h2><%= q ? `「${q}」の検索結果` : '募集中の教科書' %></h2><div class="result-meta"><strong><%= totalItems %>件</strong>見つかりました</div></div><div class="result-actions"><% if (hasActiveFilters) { %><a class="button-link secondary small-button" href="/">条件をリセット</a><% } %><% if (currentAccount) { %><a class="button-link primary small-button" href="/items/new">＋ 出品する</a><% } %></div></div>
      <% if (items.length === 0) { %>
        <div class="empty-state empty-state-v11"><div class="empty-illustration">⌕</div><strong>条件に合う譲渡品が見つかりませんでした</strong><p>キーワードを短くする、状態条件を外す、交渉中も含めるなどを試してください。</p><div class="button-row"><a class="button-link secondary" href="<%= filterChipUrls.condition %>">状態指定を外す</a><a class="button-link secondary" href="/?status=all&q=<%= encodeURIComponent(q) %>">全状態を見る</a><% if (currentAccount) { %><a class="button-link primary" href="/items/new">この教科書を出品する</a><% } %></div></div>
      <% } else { %>
        <div class="book-grid catalog-grid"><% items.forEach(item => { %><%- include("partials/item-card", { item, currentAccount, favoriteItemIds, currentUrl, recommendationReason:null, recommendationReasons:[], recommendationScore:0, showRecommendationFeedback:false, getItemStatusClass, getItemStatusLabel }) %><% }) %></div>
        <% if (totalPages > 1) { %><nav class="pagination" aria-label="検索結果のページ切り替え"><% if (currentPage > 1) { %><a href="<%= pageUrl(currentPage-1) %>">前へ</a><% } %><% for (let page=1; page<=totalPages; page+=1) { %><% if (page===1 || page===totalPages || Math.abs(page-currentPage)<=2) { %><a class="<%= page===currentPage?'active':'' %>" href="<%= pageUrl(page) %>"><%= page %></a><% } else if (page===currentPage-3 || page===currentPage+3) { %><span>…</span><% } %><% } %><% if (currentPage<totalPages) { %><a href="<%= pageUrl(currentPage+1) %>">次へ</a><% } %></nav><% } %>
      <% } %>
    </section>
  </main>

  <div class="page-loading" data-page-loading aria-hidden="true"><div class="loading-shell"><div class="loading-bar"></div><div class="skeleton-card-row"><span></span><span></span><span></span><span></span></div></div></div>
  <%- include("partials/footer") %>
</body>
</html>
