<section class="discovery-shelf" aria-labelledby="<%= shelfId %>-title">
  <div class="section-header shelf-header"><div><% if (eyebrow) { %><span class="section-eyebrow"><%= eyebrow %></span><% } %><h2 id="<%= shelfId %>-title"><%= title %></h2><% if (description) { %><p><%= description %></p><% } %></div><% if (actionHref && actionLabel) { %><a class="text-link" href="<%= actionHref %>"><%= actionLabel %><span aria-hidden="true"> →</span></a><% } %></div>
  <div class="shelf-shell"><div class="shelf-track" tabindex="0" aria-label="<%= title %>の一覧"><% items.forEach(item => { %><div class="shelf-card-wrap"><%- include("item-card", { item, currentAccount, favoriteItemIds, currentUrl, recommendationReason: reasonResolver ? reasonResolver(item) : null, recommendationReasons: reasonsResolver ? reasonsResolver(item) : [], recommendationScore: scoreResolver ? scoreResolver(item) : 0, showRecommendationFeedback: Boolean(showRecommendationFeedback), getItemStatusClass, getItemStatusLabel }) %></div><% }) %></div></div>
</section>
