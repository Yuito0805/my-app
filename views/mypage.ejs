<!DOCTYPE html>
<html lang="ja">
<%- include("partials/head", { title: "マイページ" }) %>
<body>
  <%- include("partials/nav", { currentAccount, currentPath, unreadCount }) %>
  <%- include("partials/messages", { notice, error }) %>
  <%- include("partials/onboarding", { showOnboarding, currentAccount, currentPath }) %>

  <main id="main-content" tabindex="-1">
    <% const openItems = myItems.filter(item => !item.isCanceled && !item.completedAt && !item.receiver); %>
    <% const negotiatingItems = myItems.filter(item => !item.isCanceled && !item.completedAt && item.receiver); %>

    <div class="page-header page-header-with-action">
      <div><h1>マイページ</h1><p><%= currentAccount.accountName %>さんの活動と、履修科目に合わせた教科書探しをまとめて管理できます。</p></div>
      <form action="/onboarding/reset" method="post"><button class="secondary small-button" type="submit">使い方ガイドを表示</button></form>
    </div>

    <% const updateCount = unreadItems.length + notificationSummary.length; %>
    <% const activeListingCount = openItems.length + negotiatingItems.length; %>
    <section class="mypage-overview" aria-labelledby="mypage-overview-title">
      <div class="overview-heading">
        <div>
          <span class="section-eyebrow">ACTIVITY OVERVIEW</span>
          <h2 id="mypage-overview-title">いま確認したい情報</h2>
        </div>
        <p>件数と次の操作を一つのカードにまとめています。</p>
      </div>

      <div class="dashboard-summary-grid">
        <a class="dashboard-summary-card update-summary <%= updateCount > 0 ? 'has-update' : '' %>" href="/mypage?tab=updates">
          <span class="summary-icon" aria-hidden="true">●</span>
          <span class="summary-content">
            <span class="summary-label">新規更新</span>
            <strong class="summary-number"><%= updateCount %><small>件</small></strong>
            <span class="summary-description"><%= updateCount > 0 ? '未読の通知やチャットがあります' : '現在、新しい更新はありません' %></span>
          </span>
          <span class="summary-action">更新を確認 <span aria-hidden="true">→</span></span>
        </a>

        <a class="dashboard-summary-card" href="/mypage?tab=listings">
          <span class="summary-icon" aria-hidden="true">▣</span>
          <span class="summary-content">
            <span class="summary-label">出品中</span>
            <strong class="summary-number"><%= activeListingCount %><small>件</small></strong>
            <span class="summary-description">募集中 <%= openItems.length %>件・交渉中 <%= negotiatingItems.length %>件</span>
          </span>
          <span class="summary-action">出品一覧を見る <span aria-hidden="true">→</span></span>
        </a>

        <a class="dashboard-summary-card" href="/mypage?tab=chats">
          <span class="summary-icon" aria-hidden="true">✉</span>
          <span class="summary-content">
            <span class="summary-label">問い合わせ中</span>
            <strong class="summary-number"><%= myChatThreads.length %><small>件</small></strong>
            <span class="summary-description">自分がメッセージを送った譲渡品</span>
          </span>
          <span class="summary-action">チャットを見る <span aria-hidden="true">→</span></span>
        </a>

        <a class="dashboard-summary-card" href="/mypage?tab=favorites">
          <span class="summary-icon" aria-hidden="true">♥</span>
          <span class="summary-content">
            <span class="summary-label">お気に入り</span>
            <strong class="summary-number"><%= favoriteItems.length %><small>件</small></strong>
            <span class="summary-description">あとで見たい架空教科書を保存中</span>
          </span>
          <span class="summary-action">お気に入りを見る <span aria-hidden="true">→</span></span>
        </a>
      </div>

      <div class="dashboard-quick-links" aria-label="その他のマイページ項目">
        <a href="/mypage?tab=recent"><span>最近見たもの</span><strong><%= recentViews.length %>件</strong></a>
        <a href="/mypage?tab=saved"><span>保存した検索</span><strong><%= savedSearches.length %>件</strong></a>
        <a href="/mypage?tab=courses"><span>履修科目</span><strong><%= enrolledCourses.length %>件</strong></a>
        <a href="/notifications"><span>未読通知</span><strong><%= unreadCount %>件</strong></a>
      </div>
    </section>

    <section class="activity-dashboard" aria-labelledby="recent-activity-title">
      <div class="activity-dashboard-header">
        <div><span class="section-eyebrow">RECENT ACTIVITY</span><h2 id="recent-activity-title">最近の活動</h2><p>お気に入り・閲覧・出品・チャット・通知を新しい順にまとめています。</p></div>
        <div class="activity-week-summary" aria-label="過去7日間の活動件数"><strong><%= activitySummary.total %></strong><span>過去7日間</span></div>
      </div>
      <div class="activity-layout">
        <div class="activity-stat-grid" aria-label="活動の内訳">
          <div><span>お気に入り</span><strong><%= activitySummary.favorites %>件</strong></div>
          <div><span>閲覧</span><strong><%= activitySummary.views %>件</strong></div>
          <div><span>チャット</span><strong><%= activitySummary.messages %>件</strong></div>
          <div><span>通知</span><strong><%= activitySummary.updates %>件</strong></div>
        </div>
        <% if (recentActivities.length === 0) { %>
          <div class="empty-state activity-empty"><strong>最近の活動はまだありません。</strong><p>教科書を検索したり、お気に入りに追加したりすると、ここに表示されます。</p><a class="button-link primary" href="/">教科書を探す</a></div>
        <% } else { %>
          <ol class="activity-timeline">
            <% recentActivities.forEach(activity => { %>
              <li><a href="<%= activity.href %>"><span class="activity-icon activity-<%= activity.type %>" aria-hidden="true"><%= activity.icon %></span><span class="activity-main"><span class="activity-label"><%= activity.label %></span><strong><%= activity.title %></strong><small><%= activity.description %></small></span><time datetime="<%= activity.occurredAt.toISOString() %>"><%= formatRelativeDate(activity.occurredAt) %></time><span class="activity-arrow" aria-hidden="true">›</span></a></li>
            <% }) %>
          </ol>
        <% } %>
      </div>
    </section>

    <div class="tabs mypage-tabs">
      <div class="tab-list" role="tablist" aria-label="マイページの表示切り替え">
        <button class="tab-button active" type="button" role="tab" id="tab-updates" aria-controls="panel-updates" data-tab-target="updates" aria-selected="true" tabindex="0"><span>新規更新</span><strong><%= updateCount %></strong></button>
        <button class="tab-button" type="button" role="tab" id="tab-listings" aria-controls="panel-listings" data-tab-target="listings" aria-selected="false" tabindex="-1"><span>自分の出品</span><strong><%= myItems.length %></strong></button>
        <button class="tab-button" type="button" role="tab" id="tab-chats" aria-controls="panel-chats" data-tab-target="chats" aria-selected="false" tabindex="-1"><span>問い合わせ中</span><strong><%= myChatThreads.length %></strong></button>
        <button class="tab-button" type="button" role="tab" id="tab-favorites" aria-controls="panel-favorites" data-tab-target="favorites" aria-selected="false" tabindex="-1"><span>お気に入り</span><strong><%= favoriteItems.length %></strong></button>
        <button class="tab-button" type="button" role="tab" id="tab-recent" aria-controls="panel-recent" data-tab-target="recent" aria-selected="false" tabindex="-1"><span>最近見たもの</span><strong><%= recentViews.length %></strong></button>
        <button class="tab-button" type="button" role="tab" id="tab-saved" aria-controls="panel-saved" data-tab-target="saved" aria-selected="false" tabindex="-1"><span>保存した検索</span><strong><%= savedSearches.length %></strong></button>
        <button class="tab-button" type="button" role="tab" id="tab-courses" aria-controls="panel-courses" data-tab-target="courses" aria-selected="false" tabindex="-1"><span>履修科目</span><strong><%= enrolledCourses.length %></strong></button>
      </div>
    </div>

    <section id="panel-updates" class="tab-panel active" data-tab-panel="updates" role="tabpanel" aria-labelledby="tab-updates">
      <div class="card">
        <div class="section-header">
          <div><h2>新規更新</h2><p>保存検索・お気に入り・チャットに関する未読情報をまとめています。</p></div>
          <a class="button-link secondary small-button" href="/notifications">通知センターを開く</a>
        </div>

        <% if (notificationSummary.length > 0) { %>
          <div class="notification-compact-list">
            <% notificationSummary.forEach(notification => { %>
              <a class="notification-compact-card" href="/notifications/<%= notification.id %>/open">
                <span class="notification-dot" aria-hidden="true"></span>
                <span><strong><%= notification.message %></strong><small><%= formatDate(notification.createdAt) %></small></span>
                <span aria-hidden="true">›</span>
              </a>
            <% }) %>
          </div>
        <% } %>

        <% if (unreadItems.length === 0 && notificationSummary.length === 0) { %>
          <div class="empty-state"><strong>現在、新しい更新はありません。</strong><p>新しい出品やメッセージが届くと、ここやヘッダーの通知件数に表示されます。</p></div>
        <% } else if (unreadItems.length > 0) { %>
          <h3 class="subsection-title">新しいチャット</h3>
          <div class="thread-list">
            <% unreadItems.forEach(item => { %>
              <% const latestMessage = item.chatMessages[item.chatMessages.length - 1]; %>
              <a class="thread-card" href="/items/<%= item.id %>">
                <span class="thread-icon"><img src="/images/book-placeholder.svg" alt=""></span>
                <span class="thread-main">
                  <span class="button-row"><span class="thread-title"><%= item.textbook.title %></span><span class="status update-status">新規更新</span><span class="status <%= getItemStatusClass(item) %>"><%= getItemStatusLabel(item) %></span></span>
                  <span class="thread-preview"><%= latestMessage ? `${latestMessage.sender.accountName}：${latestMessage.message}` : '新しいメッセージがあります' %></span>
                </span>
                <span class="thread-arrow">›</span>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section id="panel-listings" class="tab-panel" data-tab-panel="listings" role="tabpanel" aria-labelledby="tab-listings" hidden>
      <div class="card">
        <div class="section-header">
          <div><h2>自分の出品</h2><p>取り消し済みの出品は、取り消しから<%= canceledItemVisibleHours %>時間後に非表示になります。</p></div>
          <a class="button-link primary small-button" href="/items/new">＋ 新しく出品</a>
        </div>
        <% if (myItems.length === 0) { %>
          <div class="empty-state"><strong>まだ出品した教科書はありません。</strong><p>使い終わった教科書を出品してみましょう。</p><a class="button-link primary" href="/items/new">教科書を出品する</a></div>
        <% } else { %>
          <div class="book-grid">
            <% myItems.forEach(item => { %>
              <%- include("partials/item-card", {
                item,
                currentAccount,
                favoriteItemIds,
                currentUrl: '/mypage?tab=listings',
                recommendationReason: unreadItemIds.includes(item.id) ? '新規更新あり' : null,
                recommendationReasons: [],
                recommendationScore: 0,
                showRecommendationFeedback: false,
                getItemStatusClass,
                getItemStatusLabel
              }) %>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section id="panel-chats" class="tab-panel" data-tab-panel="chats" role="tabpanel" aria-labelledby="tab-chats" hidden>
      <div class="card">
        <div class="section-header"><div><h2>問い合わせ中の譲渡品</h2><p>自分がチャットを送った譲渡品を、重複せず一覧表示します。</p></div><a class="button-link secondary small-button" href="/">教科書を探す</a></div>
        <% if (myChatThreads.length === 0) { %>
          <div class="empty-state"><strong>まだ問い合わせた譲渡品はありません。</strong><p>気になる教科書の詳細画面から出品者へメッセージを送れます。</p><a class="button-link primary" href="/">教科書を探す</a></div>
        <% } else { %>
          <div class="thread-list">
            <% myChatThreads.forEach(thread => { %>
              <% const item = thread.item; %>
              <a class="thread-card" href="/items/<%= item.id %>">
                <span class="thread-icon"><img src="/images/book-placeholder.svg" alt=""></span>
                <span class="thread-main">
                  <span class="button-row"><span class="thread-title"><%= item.textbook.title %></span><span class="status <%= getItemStatusClass(item) %>"><%= getItemStatusLabel(item) %></span><% if (unreadItemIds.includes(item.id)) { %><span class="status update-status">新規更新</span><% } %></span>
                  <span class="thread-preview">自分：<%= thread.latestOwnMessage.message %></span>
                  <span class="meta"><%= formatDate(thread.latestOwnMessage.sentAt) %>・出品者 <%= item.seller.accountName %></span>
                </span>
                <span class="thread-arrow">›</span>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section id="panel-favorites" class="tab-panel" data-tab-panel="favorites" role="tabpanel" aria-labelledby="tab-favorites" hidden>
      <div class="card">
        <div class="section-header"><div><h2>お気に入り</h2><p>あとで確認したい教科書を保存しています。状態が変わると通知が届きます。</p></div><a class="button-link secondary small-button" href="/">教科書を探す</a></div>
        <% if (favoriteItems.length === 0) { %>
          <div class="empty-state"><strong>お気に入りはまだありません。</strong><p>譲渡品カードのハートを押すと、ここに保存できます。</p><a class="button-link primary" href="/">教科書を探す</a></div>
        <% } else { %>
          <div class="book-grid">
            <% favoriteItems.forEach(item => { %>
              <%- include("partials/item-card", {
                item,
                currentAccount,
                favoriteItemIds,
                currentUrl: '/mypage?tab=favorites',
                recommendationReason: null,
                recommendationReasons: [],
                recommendationScore: 0,
                showRecommendationFeedback: false,
                getItemStatusClass,
                getItemStatusLabel
              }) %>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section id="panel-recent" class="tab-panel" data-tab-panel="recent" role="tabpanel" aria-labelledby="tab-recent" hidden>
      <div class="card">
        <div class="section-header"><div><h2>最近見た教科書</h2><p>直近に詳細を開いた教科書を最大8件表示します。</p></div><a class="button-link secondary small-button" href="/">教科書を探す</a></div>
        <% if (recentViews.length === 0) { %>
          <div class="empty-state"><strong>閲覧履歴はまだありません。</strong><p>教科書の詳細を見ると、ここからすぐ戻れるようになります。</p></div>
        <% } else { %>
          <div class="book-grid">
            <% recentViews.forEach(view => { %>
              <% const item = view.item; %>
              <%- include("partials/item-card", {
                item,
                currentAccount,
                favoriteItemIds,
                currentUrl: '/mypage?tab=recent',
                recommendationReason: `最終閲覧：${formatDate(view.viewedAt)}`,
                recommendationReasons: [],
                recommendationScore: 0,
                showRecommendationFeedback: false,
                getItemStatusClass,
                getItemStatusLabel
              }) %>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section id="panel-courses" class="tab-panel" data-tab-panel="courses" role="tabpanel" aria-labelledby="tab-courses" hidden>
      <div class="card course-settings-card">
        <div class="section-header"><div><span class="section-eyebrow">PERSONALIZE</span><h2>履修科目を設定</h2><p>選んだ科目に関連する募集中の教科書を、トップページとおすすめで優先表示します。最大12科目まで選択できます。</p></div><a class="button-link secondary small-button" href="/">トップページで確認</a></div>
        <% if (enrolledCourses.length > 0) { %><div class="selected-course-summary"><% enrolledCourses.forEach(course => { %><span class="selected-course-chip"><%= course.courseName %><small><%= course.teacherName %></small></span><% }) %></div><% } else { %><div class="course-empty-hint"><strong>履修科目はまだ登録されていません。</strong><span>下の候補から選ぶと、教科書探しが個別化されます。</span></div><% } %>
        <form action="/account-courses" method="post" class="course-settings-form" data-course-form>
          <label class="course-filter-field"><span>科目を絞り込む</span><input type="search" placeholder="例：Web、データ、英語、法学" data-course-filter autocomplete="off"></label>
          <div class="course-selection-meta"><span>選択中 <strong data-course-count><%= enrolledCourseIds.length %></strong> / 12</span><button class="text-button" type="button" data-course-clear>すべて解除</button></div>
          <div class="course-choice-grid" data-course-grid><% allCourses.forEach(course => { %><label class="course-choice" data-course-choice data-search-text="<%= `${course.courseName} ${course.teacherName}`.toLowerCase() %>"><input type="checkbox" name="courseIds" value="<%= course.id %>" <%= enrolledCourseIds.includes(course.id) ? 'checked' : '' %>><span class="course-choice-check">✓</span><span class="course-choice-main"><strong><%= course.courseName %></strong><small><%= course.teacherName %></small></span></label><% }) %></div>
          <div class="form-actions sticky-form-actions"><button class="primary" type="submit">履修科目を保存</button><span class="meta">設定はいつでも変更できます。</span></div>
        </form>
      </div>
    </section>

    <section id="panel-saved" class="tab-panel" data-tab-panel="saved" role="tabpanel" aria-labelledby="tab-saved" hidden>
      <div class="card">
        <div class="section-header"><div><h2>保存した検索</h2><p>よく使う条件を再利用し、前回確認後の新着件数を確認できます。</p></div><a class="button-link secondary small-button" href="/">新しい条件で検索</a></div>
        <% if (savedSearches.length === 0) { %>
          <div class="empty-state"><strong>保存した検索はまだありません。</strong><p>トップページで条件を指定し、「この検索条件を保存」から登録できます。</p><a class="button-link primary" href="/">検索条件を作る</a></div>
        <% } else { %>
          <div class="saved-search-list">
            <% savedSearches.forEach(search => { %>
              <article class="saved-search-card">
                <div class="saved-search-card-main">
                  <div class="button-row">
                    <h3><%= search.name %></h3>
                    <% if (search.newItemCount > 0) { %><span class="status update-status">新着 <%= search.newItemCount %>件</span><% } %>
                  </div>
                  <p><%= search.description %></p>
                  <span class="meta">最終確認：<%= formatDate(search.lastCheckedAt) %></span>
                </div>
                <div class="saved-search-actions">
                  <a class="button-link primary small-button" href="/saved-searches/<%= search.id %>/results">結果を見る</a>
                  <form action="/saved-searches/<%= search.id %>/delete" method="post"
                    data-confirm
                    data-confirm-title="保存した検索を削除しますか？"
                    data-confirm-message="「<%= search.name %>」と、この検索に紐づく通知を削除します。"
                    data-confirm-label="削除する"
                    data-confirm-variant="danger">
                    <button class="danger small-button" type="submit">削除</button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include("partials/footer") %>
</body>
</html>
